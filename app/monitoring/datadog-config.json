{
  "version": "1.0",
  "service": "foundation-os",
  "env": "production",
  "logs": {
    "enabled": true,
    "level": "info",
    "format": "json"
  },
  "tracing": {
    "enabled": true,
    "sample_rate": 0.1,
    "analytics_enabled": true
  },
  "metrics": {
    "runtime_metrics_enabled": true,
    "custom_metrics": [
      {
        "name": "foundation_os.user.sessions",
        "type": "count",
        "tags": ["region", "user_tier"]
      },
      {
        "name": "foundation_os.workflow.executions",
        "type": "count",
        "tags": ["workflow_type", "success"]
      },
      {
        "name": "foundation_os.api.response_time",
        "type": "histogram",
        "tags": ["endpoint", "status_code", "region"]
      },
      {
        "name": "foundation_os.mcp.tool_usage",
        "type": "count",
        "tags": ["tool_name", "user_tier"]
      },
      {
        "name": "foundation_os.performance.page_load",
        "type": "histogram",
        "tags": ["page", "region", "device_type"]
      }
    ]
  },
  "alerts": [
    {
      "name": "High Error Rate",
      "query": "avg(last_5m):avg:foundation_os.errors{env:production} > 10",
      "message": "Foundation OS error rate is above threshold @pagerduty-foundation-os",
      "type": "metric alert",
      "thresholds": {
        "critical": 10,
        "warning": 5
      }
    },
    {
      "name": "High Response Time",
      "query": "avg(last_10m):avg:foundation_os.api.response_time{env:production} > 500",
      "message": "Foundation OS API response time is high @slack-foundation-os",
      "type": "metric alert",
      "thresholds": {
        "critical": 500,
        "warning": 300
      }
    },
    {
      "name": "Low Availability",
      "query": "avg(last_5m):avg:foundation_os.uptime{env:production} < 99.9",
      "message": "Foundation OS availability below SLA @pagerduty-foundation-os",
      "type": "service check",
      "thresholds": {
        "critical": 99.9,
        "warning": 99.95
      }
    }
  ],
  "dashboards": [
    {
      "name": "Foundation OS Global Overview",
      "widgets": [
        {
          "type": "timeseries",
          "title": "Active Users by Region",
          "query": "sum:foundation_os.user.sessions{*} by {region}"
        },
        {
          "type": "query_value",
          "title": "Global Uptime",
          "query": "avg:foundation_os.uptime{*}"
        },
        {
          "type": "heatmap",
          "title": "Response Time Distribution",
          "query": "avg:foundation_os.api.response_time{*} by {region,endpoint}"
        },
        {
          "type": "toplist",
          "title": "Most Used MCP Tools",
          "query": "top(sum:foundation_os.mcp.tool_usage{*} by {tool_name}, 10, 'sum', 'desc')"
        }
      ]
    }
  ]
}