{
  "font": {
    "family": {
      "sans": {
        "$value": "'Figtree', system-ui, sans-serif",
        "$type": "fontFamily"
      },
      "mono": {
        "$value": "'JetBrains Mono', 'Fira Code', monospace",
        "$type": "fontFamily"
      }
    },
    "weight": {
      "normal": { "$value": 400, "$type": "fontWeight" },
      "medium": { "$value": 500, "$type": "fontWeight" },
      "semibold": { "$value": 600, "$type": "fontWeight" },
      "bold": { "$value": 700, "$type": "fontWeight" }
    },
    "size": {
      "base": { "$value": "16px", "$type": "dimension", "$description": "Root font size (--font-size)" }
    }
  },
  "ds": {
    "text": {
      "2xs": { "$value": "0.5rem", "$type": "dimension" },
      "xs": { "$value": "0.5625rem", "$type": "dimension" },
      "sm": { "$value": "0.625rem", "$type": "dimension" },
      "md": { "$value": "0.6875rem", "$type": "dimension" },
      "base": { "$value": "0.75rem", "$type": "dimension" },
      "lg": { "$value": "0.875rem", "$type": "dimension" },
      "xl": { "$value": "1.125rem", "$type": "dimension" },
      "2xl": { "$value": "1.5rem", "$type": "dimension" },
      "display": { "$value": "1.875rem", "$type": "dimension" }
    }
  }
}
