      "canvas": { "$value": "{ds.surface.0}", "$type": "color", "$description": "Deepest background" },
      "sidebar": { "$value": "{ds.surface.1}", "$type": "color", "$description": "Sidebar/header" },
      "card": { "$value": "{ds.surface.2}", "$type": "color", "$description": "Card background" },
      "elevated": { "$value": "{ds.surface.3}", "$type": "color", "$description": "Elevated surface" }
    },
    "text": {
