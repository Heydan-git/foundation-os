    "@storybook/blocks": "8.6.18",
    "@storybook/react": "8.6.18",
    "@storybook/react-vite": "8.6.18",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "storybook": "8.6.18",
    "style-dictionary": "^4.1.4",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  }
