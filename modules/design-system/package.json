{
  "name": "@foundation-os/design-system",
  "version": "0.0.1",
  "private": true,
  "description": "Foundation OS Design System — Void Glass tokens + primitives",
  "type": "module",
  "main": "./tokens/build/tokens.js",
  "exports": {
    "./tokens.css": "./tokens/build/tokens.css",
    "./tokens": "./tokens/build/tokens.js",
    "./tokens.json": "./tokens/build/tokens.json"
  },
  "files": [
    "tokens/source",
    "tokens/build",
    "README.md"
  ],
  "scripts": {
    "build:tokens": "node scripts/build-tokens.mjs",
    "check:contrast": "node scripts/check-contrast.mjs",
    "build": "npm run build:tokens",
    "prestorybook": "npm run build:tokens",
    "storybook": "storybook dev -p 6006 --no-open --disable-telemetry",
    "prebuild-storybook": "npm run build:tokens",
    "build-storybook": "storybook build --disable-telemetry",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npx playwright test --config playwright.config.ts",
    "pretest:e2e": "npm run build-storybook"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0"
  },
  "dependencies": {
    "lucide-react": "^0.469.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.59.1",
    "@storybook/addon-a11y": "8.6.18",
    "@storybook/addon-essentials": "8.6.18",
    "@storybook/blocks": "8.6.18",
    "@storybook/react": "8.6.18",
    "@storybook/react-vite": "8.6.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.5.2",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "http-server": "^14.1.1",
    "jest-axe": "^10.0.0",
    "jsdom": "^29.0.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "storybook": "8.6.18",
    "style-dictionary": "^4.1.4",
    "typescript": "^5.3.0",
    "vite": "^8.0.8",
    "vitest": "^4.1.2"
  }
}
