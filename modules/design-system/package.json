{
  "name": "@foundation-os/design-system",
  "version": "0.0.1",
  "private": true,
  "description": "Foundation OS Design System — Void Glass dark-only, 46 composants React/TS derives base DS + 7 patterns Dashboard, tokens CSS --ds-* + Figtree/JetBrainsMono",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./styles.css": "./src/styles/globals.css",
    "./lib/utils": "./src/lib/utils.ts",
    "./components/*": "./src/components/*"
  },
  "files": [
    "src",
    "README-design-system.md"
  ],
  "scripts": {
    "build": "echo '[DS] Void Glass — no build step (src/styles/tokens.css et globals.css sont la source, consommes directement par modules/app)'",
    "storybook": "storybook dev -p 6006 --no-open --disable-telemetry",
    "build-storybook": "storybook build --disable-telemetry",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview:ds": "vite --config preview/vite.config.ts",
    "lint": "biome lint src/",
    "lint:fix": "biome lint src/ --fix",
    "supernova:analyze": "npx -y @supernovaio/cli@latest analyze --designSystemId 790241 --package @foundation-os/design-system",
    "supernova:components": "node scripts/supernova-sync.mjs",
    "supernova:import-storybook": "npm run build-storybook && npx -y @supernovaio/cli@latest storybook-import -d 790241 -f storybook-static -n \"Foundation OS DS\" --publicAccess",
    "supernova:publish": "npx -y @supernovaio/cli@latest publish-documentation --apiKey \"$SUPERNOVA_TOKEN\" --designSystemId 790241 --awaitPublishJob",
    "supernova:all": "npm run supernova:analyze && npm run supernova:components && npm run supernova:import-storybook && npm run supernova:publish"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.2.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.469.0",
    "motion": "^12.38.0",
    "next-themes": "^0.4.6",
    "react-day-picker": "^9.14.0",
    "react-hook-form": "^7.72.1",
    "react-resizable-panels": "^4.9.0",
    "react-router": "^7.14.0",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@biomejs/biome": "^2.4.11",
    "@playwright/test": "^1.59.1",
    "@storybook/addon-a11y": "9.1.20",
    "@storybook/addon-docs": "9.1.20",
    "@storybook/react-vite": "9.1.20",
    "@supernovaio/sdk": "^2.3.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.5.2",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "dotenv": "^17.4.2",
    "http-server": "^14.1.1",
    "jest-axe": "^10.0.0",
    "jsdom": "^29.0.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "storybook": "9.1.20",
    "typescript": "^5.3.0",
    "vite": "^7.3.2",
    "vitest": "^4.1.2"
  }
}
