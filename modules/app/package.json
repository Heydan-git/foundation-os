{
  "name": "foundation-os",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:production": "NODE_ENV=production tsc && vite build --mode production",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "test": "vitest",
    "test:unit": "vitest run --reporter=verbose",
    "test:coverage": "vitest --coverage",
    "deploy:staging": "vercel --target staging",
    "deploy:production": "vercel --prod --regions iad1,dub1,sin1",
    "deploy:global": "npm run build:production && npm run deploy:production",
    "health-check": "curl -f https://foundation-os.com/health || exit 1",
    "security:scan": "npm audit && snyk test",
    "performance:test": "lighthouse https://foundation-os.com --output json --quiet",
    "db:migrate": "supabase migration up",
    "db:reset": "supabase db reset",
    "monitoring:setup": "node scripts/setup-monitoring.js",
    "infrastructure:validate": "node scripts/validate-infrastructure.cjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "chromadb": "^3.4.0",
    "lucide-react": "^1.7.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.14.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitest/ui": "^4.1.2",
    "autoprefixer": "^10.4.27",
    "eslint": "^8.56.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.4",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^4.1.2"
  }
}
