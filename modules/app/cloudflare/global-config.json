{
  "zone_name": "foundation-os.com",
  "account_id": "CLOUDFLARE_ACCOUNT_ID",
  "settings": {
    "ssl": {
      "certificate_authority": "lets_encrypt",
      "ssl_tls_mode": "full",
      "min_tls_version": "1.3",
      "opportunistic_encryption": "on",
      "tls_1_3": "on",
      "automatic_https_rewrites": "on",
      "always_use_https": "on"
    },
    "performance": {
      "brotli": "on",
      "minify": {
        "css": "on",
        "html": "on",
        "js": "on"
      },
      "cache_level": "aggressive",
      "browser_cache_ttl": 31536000,
      "edge_cache_ttl": 2419200,
      "rocket_loader": "on",
      "mirage": "on",
      "polish": "lossless",
      "webp": "on",
      "early_hints": "on"
    },
    "security": {
      "waf": "on",
      "security_level": "medium",
      "challenge_passage": 1800,
      "browser_integrity_check": "on",
      "hotlink_protection": "off",
      "security_headers": {
        "strict_transport_security": {
          "enabled": true,
          "max_age": 31536000,
          "include_subdomains": true,
          "preload": true
        }
      }
    },
    "scrape_shield": {
      "email_obfuscation": "on",
      "server_side_excludes": "on",
      "hotlink_protection": "off"
    },
    "speed": {
      "railgun": "on",
      "mobile_redirect": {
        "status": "off"
      }
    }
  },
  "dns_records": [
    {
      "type": "A",
      "name": "@",
      "content": "76.76.19.19",
      "ttl": 300,
      "proxied": true
    },
    {
      "type": "CNAME",
      "name": "www",
      "content": "foundation-os.com",
      "ttl": 300,
      "proxied": true
    },
    {
      "type": "CNAME",
      "name": "us-east",
      "content": "foundation-os-us.vercel.app",
      "ttl": 300,
      "proxied": true
    },
    {
      "type": "CNAME",
      "name": "eu-west",
      "content": "foundation-os-eu.vercel.app",
      "ttl": 300,
      "proxied": true
    },
    {
      "type": "CNAME",
      "name": "asia-pacific",
      "content": "foundation-os-ap.vercel.app",
      "ttl": 300,
      "proxied": true
    },
    {
      "type": "CNAME",
      "name": "api",
      "content": "foundation-os-api.supabase.co",
      "ttl": 300,
      "proxied": true
    }
  ],
  "page_rules": [
    {
      "targets": [
        {
          "target": "url",
          "constraint": {
            "operator": "matches",
            "value": "foundation-os.com/static/*"
          }
        }
      ],
      "actions": [
        {
          "id": "cache_level",
          "value": "cache_everything"
        },
        {
          "id": "edge_cache_ttl",
          "value": 31536000
        },
        {
          "id": "browser_cache_ttl",
          "value": 31536000
        }
      ],
      "priority": 1,
      "status": "active"
    },
    {
      "targets": [
        {
          "target": "url",
          "constraint": {
            "operator": "matches",
            "value": "foundation-os.com/api/*"
          }
        }
      ],
      "actions": [
        {
          "id": "cache_level",
          "value": "bypass"
        },
        {
          "id": "security_level",
          "value": "high"
        }
      ],
      "priority": 2,
      "status": "active"
    }
  ],
  "firewall_rules": [
    {
      "filter": {
        "expression": "(ip.geoip.country in {\"CN\" \"RU\" \"KP\"}) and (cf.threat_score gt 10)",
        "paused": false,
        "description": "Block high-risk countries with threat score"
      },
      "action": "block",
      "priority": 1,
      "paused": false,
      "description": "Geographic threat protection"
    },
    {
      "filter": {
        "expression": "(http.request.uri.path contains \"admin\" or http.request.uri.path contains \"wp-\" or http.request.uri.path contains \".env\")",
        "paused": false,
        "description": "Block common attack vectors"
      },
      "action": "block",
      "priority": 2,
      "paused": false,
      "description": "Common attack vector protection"
    },
    {
      "filter": {
        "expression": "(cf.client.bot) and not (cf.verified_bot_category in {\"Search Engine\" \"Social Media\"})",
        "paused": false,
        "description": "Allow only verified bots"
      },
      "action": "challenge",
      "priority": 3,
      "paused": false,
      "description": "Bot protection"
    }
  ],
  "rate_limiting": [
    {
      "threshold": 100,
      "period": 60,
      "action": "challenge",
      "match": {
        "request": {
          "methods": ["GET", "POST"],
          "schemes": ["HTTPS"],
          "url": "foundation-os.com/api/*"
        }
      },
      "correlate": {
        "by": "ip"
      },
      "disabled": false,
      "description": "API rate limiting"
    },
    {
      "threshold": 30,
      "period": 60,
      "action": "block",
      "match": {
        "request": {
          "methods": ["POST"],
          "schemes": ["HTTPS"],
          "url": "foundation-os.com/auth/*"
        }
      },
      "correlate": {
        "by": "ip"
      },
      "disabled": false,
      "description": "Authentication rate limiting"
    }
  ],
  "workers": [
    {
      "name": "global-routing",
      "script": "addEventListener('fetch', event => {\n  event.respondWith(handleRequest(event.request))\n})\n\nasync function handleRequest(request) {\n  const url = new URL(request.url)\n  const country = request.cf.country\n  \n  // Route to appropriate region based on country\n  if (['US', 'CA', 'MX'].includes(country)) {\n    url.hostname = 'us-east.foundation-os.com'\n  } else if (['GB', 'FR', 'DE', 'IT', 'ES', 'NL'].includes(country)) {\n    url.hostname = 'eu-west.foundation-os.com'\n  } else if (['JP', 'SG', 'AU', 'IN', 'KR'].includes(country)) {\n    url.hostname = 'asia-pacific.foundation-os.com'\n  }\n  \n  return fetch(url.toString(), request)\n}",
      "routes": [
        {
          "pattern": "foundation-os.com/*",
          "zone_name": "foundation-os.com"
        }
      ]
    }
  ],
  "load_balancing": {
    "enabled": true,
    "pools": [
      {
        "name": "us-east-pool",
        "description": "US East Coast servers",
        "enabled": true,
        "minimum_origins": 1,
        "origins": [
          {
            "name": "us-east-primary",
            "address": "foundation-os-us.vercel.app",
            "enabled": true,
            "weight": 1
          }
        ],
        "monitor": "https://foundation-os-us.vercel.app/health"
      },
      {
        "name": "eu-west-pool",
        "description": "EU West servers",
        "enabled": true,
        "minimum_origins": 1,
        "origins": [
          {
            "name": "eu-west-primary",
            "address": "foundation-os-eu.vercel.app",
            "enabled": true,
            "weight": 1
          }
        ],
        "monitor": "https://foundation-os-eu.vercel.app/health"
      },
      {
        "name": "asia-pacific-pool",
        "description": "Asia Pacific servers",
        "enabled": true,
        "minimum_origins": 1,
        "origins": [
          {
            "name": "asia-pacific-primary",
            "address": "foundation-os-ap.vercel.app",
            "enabled": true,
            "weight": 1
          }
        ],
        "monitor": "https://foundation-os-ap.vercel.app/health"
      }
    ],
    "load_balancers": [
      {
        "name": "foundation-os-global",
        "description": "Global load balancer for Foundation OS",
        "ttl": 30,
        "fallback_pool": "us-east-pool",
        "default_pools": ["us-east-pool"],
        "region_pools": {
          "WEUR": ["eu-west-pool"],
          "EEUR": ["eu-west-pool"],
          "SEAS": ["asia-pacific-pool"],
          "NEAS": ["asia-pacific-pool"],
          "WNAM": ["us-east-pool"],
          "ENAM": ["us-east-pool"]
        },
        "pop_pools": {},
        "proxied": true,
        "enabled": true
      }
    ]
  },
  "analytics": {
    "web_analytics": {
      "enabled": true,
      "auto_install": true
    },
    "zone_analytics": {
      "enabled": true
    }
  }
}