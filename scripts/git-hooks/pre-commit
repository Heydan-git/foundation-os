#!/bin/bash
# Foundation OS pre-commit hook : branch-name-check + health-check
# Source : scripts/git-hooks/pre-commit (version-controlled)
# Install : cp scripts/git-hooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

# Branch name check (warning non-bloquant, convention D-NAMING-01)
if [ -x scripts/hooks/branch-name-check.sh ]; then
  bash scripts/hooks/branch-name-check.sh
fi

# Health check (bloque si BROKEN, warn si DEGRADED)
bash scripts/health-check.sh
RC=$?

if [ $RC -eq 1 ]; then
  echo ""
  echo "COMMIT BLOQUE : health-check = BROKEN"
  echo "Fixe les erreurs critiques avant de commit."
  exit 1
elif [ $RC -eq 2 ]; then
  echo ""
  echo "WARNING : health-check = DEGRADED (commit autorise)"
  exit 0
fi

exit 0
