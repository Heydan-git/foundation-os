{
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(node:*)"
    ],
    "deny": []
  },
  "model": "claude-sonnet-4-20250514",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/kevinnoel/foundation-os/scripts/hooks/check-md-pair.sh"
          },
          {
            "type": "command",
            "command": "/Users/kevinnoel/foundation-os/scripts/hooks/validate-void-glass.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash(git commit*)",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/kevinnoel/foundation-os/scripts/hooks/conventional-commit.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[FOS] Fichier modifié → penser à mettre à jour FOS-JOURNAL.md si décision importante'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '[FOS] Fin session → /session-end pour journaliser + next step'"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "oh-my-claudecode@omc": true
  }
}
